            $(".pagination:eq(0)").append(" <li><a class='back' href=\"#\">&laquo;</a></li>");
            for(var i= 0;i<PageCount;i++){
                $(".pagination:eq(0)").append("<li><a class='page' href=\"#\">"+(i+1)+"</a></li>");
            }
            $('.page:eq(0)').addClass('activePage');
            $(".pagination:eq(0)").append(" <li><a class='forward' href=\"#\">&raquo;</a></li>");

            getPageDate(currentPage,PageSize,Datacurrent);

            $(".page").on("click",function(e){
                e.preventDefault();
                $('.page').removeClass('activePage');
                $(this).addClass('activePage');
                var pageNow=$(this).text();
                getPageDate(pageNow,PageSize,Datacurrent);

            });
            //forward
            $(".forward").on("click",function(e){
                e.preventDefault();
                var s=Number($('.activePage').text());
            
                if(s==PageCount){
                        layer.msg('这是最后一页!', {icon: 6,shade: 0.4, time: 1000 });
                }else{
                        $('.page').removeClass('activePage');
                        $('.page:eq('+s+')').addClass('activePage');
                        var pageNow=$('.activePage').text();
                        getPageDate(pageNow,PageSize,Datacurrent);
                };
            });
            //back
            $(".back").on("click",function(e){
                e.preventDefault();
                var s=Number($('.activePage').text())-2;
                if(s==-1){
                        layer.msg('这是第一页!', {icon: 6,shade: 0.4, time: 1000 });
                }else{
                        $('.page').removeClass('activePage');
                        $('.page:eq('+s+')').addClass('activePage');
                        var pageNow=$('.activePage').text();
                        getPageDate(pageNow,PageSize,Datacurrent);
