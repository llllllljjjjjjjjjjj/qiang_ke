        }
    });

    /**
     * 生成静态分页
     * @param nowP 当前页
     * @param nowS 页大小
     */
    function getPageDate(nowP,nowS,data){
        var teaData="";
        var start=(nowP-1)*nowS;
        var end=((nowP-1)*nowS)+nowS;
        if(end>data.length){
            end=data.length;
        }
        for(var i=start;i<end;i++){
        
                 var classtime="";
             if((data[i].classTimeList).length>80){
                 classtime="<div class=\"classTime\">"+(data[i].classTimeCaption).substr(0,15)+"<span class='iconmore tips'></span><div class='more'><span class=\"arrowTop\"></span>"+data[i].classTimeCaption+"</div></div>";
             }else{
                 classtime=data[i].classTimeCaption;
             }
            teaData+="<tr>" +
            "<td>"+data[i].term+"</td>" +
            "<td>"+data[i].teachClassCaption+"</td>" +
            "<td>"+data[i].course+"</td>" +
            "<td>"+data[i].checkType+"</td>" +
            "<td>"+data[i].period+"</td>" +
            "<td>"+data[i].creditHour+"</td>" +
            "<td>"+classtime+"</td> " +
            "<td><a title=\"点击查看教师简历\" href=\"Resume/Resume_iniEditResume.action?teachTaskId="+data[i].teachTaskID+"\" target=\"_blank\"> "+data[i].priTeacher+"</a></td>" +
            "<td>"+data[i].maxStuNum+"</td>" +
            "<td class='stuNum'>"+data[i].selStuNum+"</td>" +
            "<td><a class='doXK btn btn-success operate' href=\"javascript:;\" dataCount="+i+">选课</a></td>" +
            "</tr>";
        }
        $("#tableTea tr:gt(0)").remove();
        $("#tableTea").append(teaData);
        getXKNum(start,end,data);
        
      //选课操作
        $(".doXK").on("click",function(){
            var i=$(this).attr("dataCount");
            GoXK(data,i);
        });
        
        $(".classTime").on('mouseover',function(){
                   $(this).find('div').css('display','block');
            }
        );
        $(".classTime").on('mouseout',function(){
                   $(this).find('div').css('display','none');
                }
        );
    }

    /**
     * 获取选课人数
     * @param data
     */
    function getXKNum(start,end,data){
        var teachTaskID="";
        for(var i=start;i<end;i++){
            teachTaskID+=data[i].teachTaskID+",";
        }
        teachTaskID="teachTasks="+teachTaskID.substring(0,teachTaskID.length-1);

        $.ajax({
            url:"TermPlan/TermPlan_getNumber.action",
            type: "post",
            data:teachTaskID,
            dataType:"json",
            beforeSend: function(){
                $(".stuNum").empty();
                $(".stuNum").css("background","url(\"images/loading.gif\") center center no-repeat");
            },
            success: function(data){
                $(".stuNum").each(function(i){
                    $(this).text(data[i].selStuNum);
                });

            },
            error: function (){
                layer.msg('系统发生异常，操作失败！', {icon: 5,shade: 0.4, time: 2000 });
            },
            complete: function(){
                $(".stuNum").css("background","none");
            }
        });
    }

